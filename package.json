{
  "name": "verso",
  "version": "0.1.0",
  "description": "Web based scanlation tool",
  "type": "module",
  "license": "MIT",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "preinstall": "bun x only-allow bun",
    "prepare": "husky",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "pixi.js": "^8.19.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
